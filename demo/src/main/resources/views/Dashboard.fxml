<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>


<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@../style/style.css" xmlns="http://javafx.com" xmlns:fx="http://javafx.com" fx:controller="com.lostfound.controllers.DashboardController">
        <Pane style="-fx-background-color: rgba(0, 0, 0, 0.5);" />
    <!-- LEFT SIDEBAR -->
    <top>
        <HBox fx:id="customTitleBar" alignment="CENTER_RIGHT" spacing="10" 
              style="-fx-background-color: #2c3e50; -fx-padding: 8 15;">
            
            <Text text="Lost &amp; Found Portal" fill="white" style="-fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" /> <!-- Spacer -->
            
            <!-- Custom Buttons -->
            <Button text="—" onAction="#handleMinimize" styleClass="window-btn"/>
            <Button text="✕" onAction="#handleClose" styleClass="window-btn-close"/>
        </HBox>
    </top>
    <left>
        <VBox spacing="15" prefWidth="220" style="-fx-background-color: #2c3e50; -fx-padding: 20;">
            <children>
                <Text text="Lost &amp; Found" fill="white" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Separator opacity="0.3"/>
                
                <Button text="My Items" maxWidth="Infinity" styleClass="side-button" onAction="#handleMyItems"/>
                <Button text="View All Items" maxWidth="Infinity" styleClass="side-button" onAction="#handleViewAll"/>
                <Button text="Report Found Item" maxWidth="Infinity" styleClass="side-button" onAction="#handleReportFound"/>
                <Button text="Report Lost Item" maxWidth="Infinity" styleClass="side-button" onAction="#handleReportLost"/>
                <StackPane alignment="TOP_RIGHT">
                <Button text="Notifications" maxWidth="Infinity" styleClass="side-button" onAction="#handleNotifications"/>
    
                <StackPane fx:id="notificationBadge" mouseTransparent="true" visible="false" maxWidth="-Infinity" maxHeight="-Infinity">
                    <Circle radius="9" fill="#ff4d4d" stroke="white" strokeType="INSIDE" strokeWidth="1.5"/>
                    <Label fx:id="badgeCount" text="0" textFill="white" style="-fx-font-size: 10px; -fx-font-weight: bold;"/>
                <StackPane.margin>
                    <Insets top="2" right="5"/>
                </StackPane.margin>
    </StackPane>
</StackPane>
                
                <Region VBox.vgrow="ALWAYS" />
                
                <Button text="Logout" maxWidth="Infinity" style="-fx-background-color: #e74c3c; -fx-text-fill: white;" onAction="#handleLogout"/>
            </children>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <VBox spacing="10" style="-fx-padding: 20;">
            <Label fx:id="welcomeLabel" text="Welcome to Dashboard" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <TableView fx:id="itemTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameCol" text="Item Name" prefWidth="150" />
                    <TableColumn fx:id="categoryCol" text="Category" prefWidth="120" />
                    <TableColumn fx:id="locationCol" text="Location" prefWidth="150" />
                    <TableColumn fx:id="dateCol" text="Date Reported" prefWidth="120" />
                    <TableColumn fx:id="typeCol" text="Type" prefWidth="100" />
                    <TableColumn fx:id="desCol" text="Desciption" prefWidth="300" />
                </columns>
            </TableView>
        </VBox>
    </center>
    
</BorderPane>
